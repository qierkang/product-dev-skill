# 默认作者，写入 manifest 和初始化文档头部
PRODUCT_DEV_OWNER=qierkang+codex

# 默认 request 输出目录
PRODUCT_DEV_REQUESTS_DIR=workspace/requests

# install/sync.sh 同步到各运行端 skill 目录时使用
TARGET_CODEX_SKILLS_DIR=$HOME/.codex/skills
TARGET_CLAUDE_SKILLS_DIR=$HOME/.claude/skills
TARGET_OPENCLAW_SKILLS_DIR=$HOME/.openclaw/skills
TARGET_OPENCODE_SKILLS_DIR=$HOME/.opencode/skills

# 同步后的技能包目录名
SKILL_NAME=product-dev-skill
